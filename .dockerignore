# ── Git / VCS ────────────────────────────────────────────────────────────────
# .git is excluded from the build context (saves ~100MB+). At runtime the host
# repo is bind-mounted at /opt/hermes-agent with full .git history.
.git

# ── Python artifacts ─────────────────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.egg-info
.venv
venv
.pytest_cache
.mypy_cache
.ruff_cache

# ── Node artifacts ───────────────────────────────────────────────────────────
node_modules
.venv

# ── Docker build context exclusions ─────────────────────────────────────────
hermes-data
workspace
docker-compose.yaml
docker-compose.yml

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo

# ── Logs and data ────────────────────────────────────────────────────────────
logs
data
wandb
testlogs
tmp

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.ppk
.md

# ── Large / unnecessary directories ─────────────────────────────────────────
tinker-atropos
website
landingpage
assets
images
docs/migration
